---
import { Image } from 'astro:assets'
import Seo from '../components/Seo.astro'
import '../scss/fonts.scss'

import logoImg from '../assets/image/icon/logo.svg'
import searchImg from '../assets/image/icon/search.svg'
import networkImg from '../assets/image/icon/network.svg'

import { languages, useTranslations, type Lang } from '../i18n'

const { title, description, lang = 'ru' } = Astro.props
const currentLang = lang as Lang
const t = useTranslations(currentLang)

// Build language switch URLs — preserve the current path structure
const currentPath = Astro.url.pathname
const pathSegments = currentPath.split('/').filter(Boolean)
// Remove the lang prefix (first segment) and get the rest of the path
const restOfPath =
	pathSegments.length > 1 ? '/' + pathSegments.slice(1).join('/') : ''
---

<html lang={currentLang}>
	<head>
		<Seo {title} {description} lang={currentLang} />
	</head>
	<body>
		<header class='header container'>
			<div class='header__logo'>
				<button
					id='burger-btn'
					class='unstyled-btn burger-wrapper'
					aria-label='Toggle menu'
					aria-expanded='false'
				>
					<div class='burger-lines'>
						<span class='line line-1'></span>
						<span class='line line-2'></span>
						<span class='line line-3'></span>
					</div>
				</button>
				<a href={`/${currentLang}`}>
					<Image src={logoImg} alt='MEX logo' width={124} height={28} />
				</a>
			</div>

			<nav id='mobile-nav'>
				<ul>
					<li><a href='#main'>{t('nav.main')}</a></li>
					<li><a href='#news'>{t('nav.news')}</a></li>
				</ul>
			</nav>

			<div class='header__button'>
				<Image src={searchImg} alt='search icon' width={24} height={24} />
				<button id='lang-toggle' class='unstyled-btn lang-toggle-btn'>
					<Image src={networkImg} alt='network icon' width={24} height={24} />
				</button>
				<!-- Til tanlash dropdown -->
				<div id='lang-dropdown' class='lang-dropdown'>
					<ul>
						{
							Object.entries(languages).map(([code, label]) => (
								<li>
									<a
										href={`/${code}${restOfPath}`}
										class={code === currentLang ? 'active' : ''}
									>
										{label}
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</header>

		<main>
			<slot />
		</main>

		<footer></footer>
	</body>
</html>

<style lang='scss'>
	@use '../scss/variables' as vrb;
	@use '../scss/mixins' as mxn;
	@use '../scss/fonts.scss';

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		background-color: vrb.$mobile-bg-color;
		color: #fff;
		overflow-x: hidden;

		@media (min-width: 768px) {
			background-color: vrb.$desktop-bg-color;
		}
	}

	.container {
		width: calc(100% - 32px);
		margin: 0 auto;

		@media (min-width: 768px) {
			width: calc(100% - 80px);
		}

		@media (min-width: 2500px) {
			width: 1600px;
			margin: 0 auto;
		}
	}

	.burger-wrapper {
		width: 30px;
		height: 24px;
		position: relative;
		z-index: 1001;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.burger-lines {
		width: 90%;
		height: 18px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;

		.line {
			width: 100%;
			height: 2px;
			background-color: #fff;
			border-radius: 2px;
			display: block;
		}
	}

	.unstyled-btn {
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
		display: inline-flex;
	}

	.header {
		position: sticky;
		top: 0px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 8px 0;
		z-index: 10000;

		&__logo {
			display: flex;
			align-items: center;
			gap: 20px;
			z-index: 1001;
		}

		nav {
			display: none;

			@media (max-width: 799px) {
				position: fixed;
				top: 0;
				left: 0;
				width: 100vw;
				height: 100vh;
				background-color: vrb.$desktop-bg-color;
				backdrop-filter: blur(25px);
				-webkit-backdrop-filter: blur(25px);
				z-index: 990;
				margin: 0;

				ul {
					height: 100%;
					display: flex;
					flex-direction: column;
					justify-content: center;
					align-items: center;
					gap: 50px;
					list-style: none;

					li a {
						color: #fff;
						text-decoration: none;
						font-size: 36px;
						font-weight: 700;
						font-family: 'source', sans-serif;
						display: block;
						text-transform: uppercase;
						letter-spacing: 4px;
						text-shadow: 0 4px 20px rgba(247, 161, 76, 0.3);
					}
				}
			}
		}

		&__button {
			z-index: 1001;
			display: flex;
			align-items: center;
			gap: 12px;
			position: relative;

			[alt='search icon'] {
				display: none;
			}

			.lang-toggle-btn {
				display: flex;
				align-items: center;
				justify-content: center;
			}
		}

		// Telefon uchun scroll bo'lganda qo'shiladigan glass effect
		@media (max-width: 767px) {
			&.scrolled {
				width: 100%;
				margin: 0;
				padding-left: 16px;
				padding-right: 16px;
				border: 1px solid rgba(255, 255, 255, 0.017);
				box-shadow:
					inset 0 0.3px 2px rgba(255, 255, 255, 0.744),
					0 5px 20px rgba(0, 0, 0, 0.5);
				background-color: rgba(0, 0, 0, 0.3);
				backdrop-filter: blur(100px);
				-webkit-backdrop-filter: blur(100px);
			}
		}

		@media (min-width: 768px) {
			position: fixed;
			left: 50%;
			transform: translateX(-50%);
			margin-top: 20px;
			border-radius: 99px;
			padding: 12px 24px;
			border: 1px solid rgba(255, 255, 255, 0.017);
			box-shadow:
				inset 0 0.3px 2px rgba(255, 255, 255, 0.744),
				0 5px 20px rgba(0, 0, 0, 0.5);
			background-color: rgba(0, 0, 0, 0.3);
			backdrop-filter: blur(100px);
			-webkit-backdrop-filter: blur(100px);

			&__logo {
				.burger-wrapper {
					display: none;
				}
			}

			nav {
				position: absolute !important;
				left: 50% !important;
				top: auto !important;
				transform: translateX(-50%) !important;
				width: auto !important;
				height: auto !important;
				background: none !important;
				backdrop-filter: none !important;
				display: block !important;

				ul {
					display: flex !important;
					flex-direction: row !important;
					align-items: center;
					gap: 20px;
					list-style: none;
					height: auto !important;

					li {
						opacity: 1 !important;
						transform: none !important;
						padding: 4px 0;

						a {
							color: #fff;
							text-decoration: none;
							font-size: 16px !important;
							font-weight: 400 !important;
							font-family: 'source', sans-serif;
							display: inline-block !important;
							text-transform: none !important;
							letter-spacing: 0 !important;
							text-shadow: none !important;
						}

						&:first-child {
							border-bottom: 2px solid #f7a14c;
						}
					}
				}
			}
		}
	}

	// Til dropdown stili
	.lang-dropdown {
		position: absolute;
		top: calc(100% + 10px);
		right: 0;
		margin-top: 5px;
		min-width: 150px;
		border-radius: 16px;
		z-index: 99999;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;

		border: 1px solid rgba(255, 255, 255, 0.017);
		box-shadow:
			inset 0 1px 3px rgba(214, 213, 213, 0.744),
			0 5px 20px rgba(26, 26, 26, 0.994);
		background-color: rgba(39, 39, 39, 0.7);
		backdrop-filter: blur(100px);
		-webkit-backdrop-filter: blur(100px);

		ul {
			list-style: none;
			margin: 0;
			padding: 0;

			li {
				margin: 0;

				a {
					display: block;
					padding: 13px 20px;
					color: #fff;
					text-decoration: none;
					font-family: 'source', sans-serif;
					font-size: 14px;
					font-weight: 400;
					transition: background-color 0.2s ease;

					&:hover {
						background-color: rgba(255, 255, 255, 0.1);
					}

					&.active {
						color: #f7a14c;
						font-weight: 600;
					}
				}
			}

			li:first-child a {
				border-top-left-radius: 16px;
				border-top-right-radius: 16px;
			}

			li:last-child a {
				border-bottom-left-radius: 16px;
				border-bottom-right-radius: 16px;
			}
		}
	}
</style>

<script>
	import { gsap } from 'gsap'

	const initMobileMenu = () => {
		const burgerBtn = document.getElementById('burger-btn')
		const nav = document.getElementById('mobile-nav')
		const navItems = document.querySelectorAll('#mobile-nav ul li')
		const line1 = document.querySelector('.line-1')
		const line2 = document.querySelector('.line-2')
		const line3 = document.querySelector('.line-3')

		if (!burgerBtn || !nav || !line1 || !line2 || !line3) return

		const tl = gsap.timeline({ paused: true, reversed: true })

		tl.to(line2, { opacity: 0, duration: 0.2 }, 0)
			.to(line1, { y: 8, rotation: 45, duration: 0.3, ease: 'power2.inOut' }, 0)
			.to(
				line3,
				{ y: -8, rotation: -45, duration: 0.3, ease: 'power2.inOut' },
				0,
			)
			.set(nav, { display: 'block', xPercent: -100, x: 0 }, 0)
			.to(nav, { xPercent: 0, duration: 0.6, ease: 'expo.out' }, 0.1)
			.fromTo(
				navItems,
				{ opacity: 0, x: -30, scale: 0.9 },
				{
					opacity: 1,
					x: 0,
					scale: 1,
					duration: 0.4,
					stagger: 0.1,
					ease: 'back.out(1.7)',
					clearProps: 'transform',
				},
				'-=0.3',
			)

		const resetDesktop = () => {
			if (window.innerWidth >= 800) {
				tl.progress(0).pause()
				tl.reversed(true)
				nav.classList.remove('mobile-open')
				burgerBtn.setAttribute('aria-expanded', 'false')
				gsap.set([nav, navItems, line1, line2, line3], { clearProps: 'all' })
			}
		}

		window.addEventListener('resize', resetDesktop)

		burgerBtn.addEventListener('click', () => {
			if (window.innerWidth >= 800) return

			const isReversed = tl.reversed()
			burgerBtn.setAttribute('aria-expanded', isReversed ? 'true' : 'false')

			if (isReversed) {
				nav.classList.add('mobile-open')
				tl.play()
			} else {
				tl.reverse().then(() => {
					nav.classList.remove('mobile-open')
				})
			}
		})
	}

	// Scroll orqali header fonini o'zgartirish (faqat telefonlar uchun)
	const initScrollHeader = () => {
		const header = document.querySelector('.header')
		if (!header) return

		const handleScroll = () => {
			if (window.innerWidth >= 768) {
				header.classList.remove('scrolled')
				if (!header.classList.contains('container')) {
					header.classList.add('container')
				}
				return
			}

			if (window.scrollY > 0) {
				header.classList.add('scrolled')
				header.classList.remove('container')
			} else {
				header.classList.remove('scrolled')
				header.classList.add('container')
			}
		}
		handleScroll()
		window.addEventListener('scroll', handleScroll, { passive: true })
		window.addEventListener('resize', handleScroll)
	}

	// Til dropdown animatsiyasi
	const initLangDropdown = () => {
		const toggleBtn = document.getElementById('lang-toggle')
		const dropdown = document.getElementById('lang-dropdown')

		if (!toggleBtn || !dropdown) return

		let isOpen = false
		let animating = false
		let tl

		const createTimeline = () => {
			tl = gsap.timeline({
				paused: true,
				onStart: () => {
					animating = true
				},
				onComplete: () => {
					animating = false
				},
			})

			// Ochilish animatsiyasi
			tl.set(dropdown, { display: 'block', visibility: 'visible' })
				.fromTo(
					dropdown,
					{ y: -15, opacity: 0, scale: 0.95 },
					{ y: 0, opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.2)' },
				)
				.set(dropdown, { pointerEvents: 'auto' })

			// Yopilish animatsiyasi (timeline ichida teskari yo'nalishda ishlatiladi)
		}

		createTimeline()

		const openDropdown = () => {
			if (animating) return
			tl.play()
			isOpen = true
			toggleBtn.setAttribute('aria-expanded', 'true')
		}

		const closeDropdown = () => {
			if (animating) return
			tl.reverse().then(() => {
				gsap.set(dropdown, { display: 'none', pointerEvents: 'none' })
			})
			isOpen = false
			toggleBtn.setAttribute('aria-expanded', 'false')
		}

		toggleBtn.addEventListener('click', e => {
			e.stopPropagation()
			if (isOpen) {
				closeDropdown()
			} else {
				openDropdown()
			}
		})

		// Tashqariga bosganda yopish
		document.addEventListener('click', e => {
			if (
				isOpen &&
				!toggleBtn.contains(e.target) &&
				!dropdown.contains(e.target)
			) {
				closeDropdown()
			}
		})

		// Escape tugmasi
		document.addEventListener('keydown', e => {
			if (e.key === 'Escape' && isOpen) {
				closeDropdown()
			}
		})

		// Resize bo'lganda yopish (agar kerak bo'lsa)
		window.addEventListener('resize', () => {
			if (isOpen) {
				closeDropdown()
			}
		})
	}

	document.addEventListener('DOMContentLoaded', () => {
		initMobileMenu()
		initScrollHeader()
		initLangDropdown()
	})

	document.addEventListener('astro:page-load', () => {
		initMobileMenu()
		initScrollHeader()
		initLangDropdown()
	})
</script>

---
import '../scss/fonts.scss'

const { label = 'About', heading = 'Not just a chat app, but an ecosystem' } =
	Astro.props
---

<section class='about container'>
	<div class='about__content'>
		<div><p>{label}</p></div>
		<h2>{heading}</h2>
	</div>
</section>

<style lang='scss'>
	@use '../scss/variables' as vrb;
	@use '../scss/mixins' as mxn;

	@use '../scss/fonts.scss';

	.container {
		width: calc(100% - 32px);
		margin: 0 auto;

		@media (min-width: 768px) {
			width: calc(100% - 80px);
		}
	}

	.about {
		display: flex;
		flex-direction: column;
		gap: 32px;
		border: 1px solid red;
		padding: {
			top: 100px;
		}

		&__content {
			border: 1px solid red;
			display: flex;
			flex-direction: column;
			gap: 24px;
			align-items: center;

			div {
				padding: 8px 20px;
				border-radius: 8px;
				border: 1px solid rgba(255, 255, 255, 0.017);
				box-shadow:
					inset 0 0.3px 2px rgba(255, 255, 255, 0.744),
					0 5px 20px rgba(0, 0, 0, 0.5);
				background-color: rgba(0, 0, 0, 0.3);
				backdrop-filter: blur(100px);
				-webkit-backdrop-filter: blur(100px);
				font-size: 12px;
				text-transform: uppercase;
				font-weight: 400;
				font-family: 'clash', sans-serif;

				@media (min-width: 520px) {
					font-size: 18px;
				}

				@media (min-width: 768px) {
					font-size: 24px;
				}
			}

			h2 {
				border: 1px solid red;
				font-size: 24px;
				text-align: center;
				font-family: 'clash', sans-serif;
				text-transform: uppercase;
				font-weight: 700;

				@media (min-width: 520px) {
					font-size: 34px;
				}

				@media (min-width: 768px) {
					font-size: 55px;
				}

				@media (min-width: 960px) {
					font-size: 64px;
				}

				@media (min-width: 1200px) {
					width: 70%;
				}

				@media (min-width: 1400px) {
					width: 50%;
					font-size: 72px;
				}
			}

			h2,
			p {
				padding: 0;
				margin: 0;
			}
		}
	}
</style>

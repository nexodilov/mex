---
import { Image } from 'astro:assets'
import AboutBg from '../assets/image/about-bg.png'
import '../scss/fonts.scss'

const { label = 'About', heading = 'Not just a chat app, but an ecosystem' } =
	Astro.props
---

<section class='about'>
	<div class='canvas'>
		<div class='glow glow-deep-blue'></div>
		<div class='glow glow-soft-blue'></div>
		<div class='glow glow-center-white'></div>
	</div>
	<div class='about__content'>
		<div><p>{label}</p></div>
		<h2>{heading}</h2>
	</div>
	<div class='about_image'>
		<Image
			src={AboutBg}
			alt='Background image for the about section'
			class='about__background'
		/>
		<div class='circle'>
			<div class='circle-text-wrapper'>
				<svg class='circle-svg' viewBox='0 0 300 300'>
					<defs>
						<path
							id='circlePath'
							d='M 150, 150 m -115, 0 a 115,115 0 1,1 230,0 a 115,115 0 1,1 -230,0'
						></path>
					</defs>
					<text class='circle-text'>
						<textPath href='#circlePath' startOffset='0%'>
							Decentralization · Payments · MiniApps · Mall · Entertainment
						</textPath>
					</text>
				</svg>
			</div>
			<span class='mex-text'>MEX</span>
		</div>
	</div>
</section>

<style lang='scss'>
	@use '../scss/variables' as vrb;
	@use '../scss/mixins' as mxn;

	@use '../scss/fonts.scss';

	body {
		overflow-x: hidden;
	}

	.container {
		width: calc(100% - 32px);
		margin: 0 auto;
		overflow: hidden;

		@media (min-width: 768px) {
			width: calc(100% - 80px);
		}
	}

	.about {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 32px;
		border: 1px solid red;
		overflow: hidden;
		padding: {
			top: 100px;
			bottom: 0;
			left: 16px;
			right: 16px;
		}

		&_image {
			border: 1px solid red;
			position: relative;

			.about__background {
				top: 0;
				left: 50%;
				transform: translateX(-50%);
				width: 310px;
				height: 310px;
				border: 1px solid red;
				position: relative;

				@media (min-width: 375px) {
					width: 400px;
					height: 400px;
				}
			}
		}

		/* Effektlar uchun asosiy konteyner */
		.canvas {
			position: absolute;
			top: -5pc;
			right: 5pc;
			width: 50px;
			height: 50px;
			display: flex;
			justify-content: center;
			align-items: center;
		}

		/* Umumiy tumanli effektlar uchun klas */
		.glow {
			position: absolute;
			border-radius: 50%;
			filter: blur(80px); /* Tumanli effekt berish */
			pointer-events: none;
		}

		/* Ko'k-binafsha katta tuman (Rasmning o'ng va pastki qismida) */
		.glow-deep-blue {
			width: 500px;
			height: 400px;
			background: radial-gradient(
				circle,
				rgba(18, 32, 107, 0.6) 0%,
				rgba(0, 0, 0, 0) 70%
			);
			top: 20%;
			left: 40%;
			z-index: 1;
		}

		/* O'rtadagi yumshoq ko'k rang */
		.glow-soft-blue {
			width: 450px;
			height: 350px;
			background: radial-gradient(
				circle,
				rgba(40, 60, 150, 0.4) 0%,
				rgba(0, 0, 0, 0) 75%
			);
			top: 30%;
			left: 25%;
			z-index: 2;
		}

		/* Markazdagi oqish-kulrang yorqin nuqta (Asosiy fokus) */
		.glow-center-white {
			width: 280px;
			height: 250px;
			background: radial-gradient(
				circle,
				rgba(200, 210, 255, 0.25) 0%,
				rgba(0, 0, 0, 0) 80%
			);
			top: 35%;
			left: 20%;
			z-index: 3;
			filter: blur(60px);
		}

		/* Dekorativ o'ng tomondagi qorong'u chiziq (Rasmga o'xshatish uchun) */
		.side-overlay {
			position: absolute;
			right: 0;
			top: 0;
			width: 20%;
			height: 100%;
			background-color: rgba(25, 25, 25, 0.9);
			z-index: 10;
			border-left: 1px solid rgba(255, 255, 255, 0.05);
		}

		/* Animatsiya qo'shamiz - nafas olish effekti */
		@keyframes pulse {
			0%,
			100% {
				transform: scale(1);
				opacity: 0.8;
			}
			50% {
				transform: scale(1.1);
				opacity: 1;
			}
		}

		.glow {
			animation: pulse 8s infinite ease-in-out;
		}

		.glow-soft-blue {
			animation-delay: 2s;
		}

		&__content {
			border: 1px solid red;
			display: flex;
			flex-direction: column;
			gap: 24px;
			align-items: center;

			div {
				padding: 8px 20px;
				border-radius: 8px;
				border: 1px solid rgba(255, 255, 255, 0.017);
				box-shadow:
					inset 0 0.3px 2px rgba(255, 255, 255, 0.744),
					0 5px 20px rgba(0, 0, 0, 0.5);
				background-color: rgba(0, 0, 0, 0.3);
				backdrop-filter: blur(100px);
				-webkit-backdrop-filter: blur(100px);
				font-size: 12px;
				text-transform: uppercase;
				font-weight: 400;
				font-family: 'clash', sans-serif;

				@media (min-width: 520px) {
					font-size: 18px;
				}

				@media (min-width: 768px) {
					font-size: 24px;
				}
			}

			h2 {
				border: 1px solid red;
				font-size: 24px;
				text-align: center;
				font-family: 'clash', sans-serif;
				text-transform: uppercase;
				font-weight: 700;

				@media (min-width: 520px) {
					font-size: 34px;
				}

				@media (min-width: 768px) {
					font-size: 55px;
				}

				@media (min-width: 960px) {
					font-size: 64px;
				}

				@media (min-width: 1200px) {
					width: 70%;
				}

				@media (min-width: 1400px) {
					width: 50%;
					font-size: 72px;
				}
			}

			h2,
			p {
				padding: 0;
				margin: 0;
			}
		}
		.circle {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			width: 260px;
			height: 260px;
			border-radius: 50%;
			display: flex;
			justify-content: center;
			align-items: center;
			overflow: hidden;
		}

		.circle-text-wrapper {
			width: 90%;
			height: 90%;
			position: absolute;
			animation: spin 15s linear infinite;

			@media (min-width: 375px) {
				width: 120%;
				height: 120%;
			}
		}

		.circle-svg {
			width: 100%;
			height: 100%;
			overflow: visible;
		}

		.circle-text {
			fill: white;
			font-size: 14px;
			font-family: 'clash', sans-serif;
			font-weight: 600;
			letter-spacing: 3.3px;
			text-transform: uppercase;
		}

		.mex-text {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			font-size: 36px;
			font-family: 'clash', sans-serif;
			font-weight: 700;
			color: white;
			letter-spacing: 4px;
			z-index: 2;
		}

		@keyframes spin {
			0% {
				transform: rotate(0deg);
			}
			100% {
				transform: rotate(360deg);
			}
		}
	}
</style>

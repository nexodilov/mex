---
import { Image } from 'astro:assets'
import AboutBg from '../assets/image/about-bg.png'
import '../scss/fonts.scss'

const { label = 'About', heading = 'Not just a chat app, but an ecosystem' } =
	Astro.props
---

<section class='about'>
	<div class='canvas'>
		<div class='glow glow-deep-blue'></div>
		<div class='glow glow-soft-blue'></div>
		<div class='glow glow-center-white'></div>
	</div>
	<div class='about__content'>
		<div><p>{label}</p></div>
		<h2>{heading}</h2>
	</div>
	<div class='about_image'>
		<Image
			src={AboutBg}
			alt='Background image for the about section'
			class='about__background'
		/>
		<div class='circle'>
			<div class='circle-text-wrapper'>
				<svg class='circle-svg' viewBox='0 0 300 300'>
					<defs>
						<path
							id='circlePath'
							d='M 150, 150 m -115, 0 a 115,115 0 1,1 230,0 a 115,115 0 1,1 -230,0'
						></path>
					</defs>
					<text class='circle-text'>
						<textPath href='#circlePath' startOffset='0%'>
							Decentralization · Payments · MiniApps · Mall · Entertainment
						</textPath>
					</text>
				</svg>
			</div>
			<span class='mex-text'>MEX</span>
		</div>
	</div>
	<div class='about__cards'>
		<div class='container'>
			<!-- Atrofdagi juda kuchsiz fon yorug'ligi -->
			<div class='ambient-glow'></div>

			<!-- Markaziy aylana olovli yorug'lik elementi -->
			<div class='fire-orb'></div>
		</div>
		<div class='card'>
			<h3>Modern Messenger</h3>
			<p>
				A modern messenger that meets all key user needs, including calls,
				interactive messaging, and group communication, with a mini-app
				ecosystem that expands user capabilities and enables rapid product
				growth.
			</p>
		</div>
		<div class='card'>
			<h3>Financial services</h3>
			<p>
				A modern messenger that meets all key user needs, including calls,
				interactive messaging, and group communication, with a mini-app
				ecosystem that expands user capabilities and enables rapid product
				growth.
			</p>
		</div>
		<div class='card'>
			<h3>MINI APPS infrastructure</h3>
			<p>
				A robust financial infrastructure integrating card and payment
				solutions, decentralized financial services, digital assets, as well as
				investment, lending, and financial inclusion tools for the population.
			</p>
		</div>
		<div class='card'>
			<h3 class='colorful'>Private protocol R&D <span>(coming soon)</span></h3>
			<p>
				It is already clear that the future belongs to super apps, and whoever
				can competently combine all these functions will receive a loyal
				audience and a stable income.
			</p>
		</div>
		<div class='card'>
			<h3 class='colorful'>
				NAtive implementation of AI <span>(coming soon)</span>
			</h3>
			<p>
				It is already clear that the future belongs to super apps, and whoever
				can competently combine all these functions will receive a loyal
				audience and a stable income.
			</p>
		</div>
	</div>
</section>

<style lang='scss'>
	@use '../scss/variables' as vrb;
	@use '../scss/mixins' as mxn;

	@use '../scss/fonts.scss';

	body {
		overflow-x: hidden;
	}

	.about {
		position: relative;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		padding: {
			top: 100px;
			bottom: 0;
			left: 16px;
			right: 16px;
		}

		@media (min-width: 1440px) {
			padding: 220px 100px 0;
			gap: 62px;
		}

		&_image {
			position: relative;

			@media (min-width: 1440px) {
				position: absolute;
				bottom: 0;
				left: 50%;
				transform: translateX(-50%);
			}

			.about__background {
				top: 0;
				left: 50%;
				transform: translateX(-50%);
				width: 310px;
				height: 310px;

				position: relative;

				@media (min-width: 375px) {
					width: 400px;
					height: 400px;
				}

				@media (min-width: 760px) {
					width: 600px;
					height: 600px;
				}

				@media (min-width: 830px) {
					width: 700px;
					height: 700px;
				}

				@media (min-width: 1440px) {
					width: 800px;
					height: 800px;
				}
			}
		}

		/* Effektlar uchun asosiy konteyner */
		.canvas {
			position: absolute;
			top: -5pc;
			right: 5pc;
			width: 50px;
			height: 50px;
			display: flex;
			justify-content: center;
			align-items: center;
		}

		/* Umumiy tumanli effektlar uchun klas */
		.glow {
			position: absolute;
			border-radius: 50%;
			filter: blur(80px); /* Tumanli effekt berish */
			pointer-events: none;
		}

		/* Ko'k-binafsha katta tuman (Rasmning o'ng va pastki qismida) */
		.glow-deep-blue {
			width: 500px;
			height: 400px;
			background: radial-gradient(
				circle,
				rgba(18, 32, 107, 0.6) 0%,
				rgba(0, 0, 0, 0) 70%
			);
			top: 20%;
			left: 40%;
			z-index: 1;
		}

		/* O'rtadagi yumshoq ko'k rang */
		.glow-soft-blue {
			width: 450px;
			height: 350px;
			background: radial-gradient(
				circle,
				rgba(40, 60, 150, 0.4) 0%,
				rgba(0, 0, 0, 0) 75%
			);
			top: 30%;
			left: 25%;
			z-index: 2;
		}

		/* Markazdagi oqish-kulrang yorqin nuqta (Asosiy fokus) */
		.glow-center-white {
			width: 280px;
			height: 250px;
			background: radial-gradient(
				circle,
				rgba(200, 210, 255, 0.25) 0%,
				rgba(0, 0, 0, 0) 80%
			);
			top: 35%;
			left: 20%;
			z-index: 3;
			filter: blur(60px);
		}

		/* Dekorativ o'ng tomondagi qorong'u chiziq (Rasmga o'xshatish uchun) */
		.side-overlay {
			position: absolute;
			right: 0;
			top: 0;
			width: 20%;
			height: 100%;
			background-color: rgba(25, 25, 25, 0.9);
			z-index: 10;
			border-left: 1px solid rgba(255, 255, 255, 0.05);
		}

		/* Animatsiya qo'shamiz - nafas olish effekti */
		@keyframes pulse {
			0%,
			100% {
				transform: scale(1);
				opacity: 0.8;
			}
			50% {
				transform: scale(1.1);
				opacity: 1;
			}
		}

		.glow {
			animation: pulse 8s infinite ease-in-out;
		}

		.glow-soft-blue {
			animation-delay: 2s;
		}

		&__content {
			display: flex;
			flex-direction: column;
			gap: 24px;
			align-items: center;

			div {
				padding: 8px 20px;
				border-radius: 8px;
				border: 1px solid rgba(255, 255, 255, 0.017);
				box-shadow:
					inset 0 0.3px 2px rgba(255, 255, 255, 0.744),
					0 5px 20px rgba(0, 0, 0, 0.5);
				background-color: rgba(0, 0, 0, 0.3);
				backdrop-filter: blur(100px);
				-webkit-backdrop-filter: blur(100px);
				font-size: 12px;
				text-transform: uppercase;
				font-weight: 400;
				font-family: 'clash', sans-serif;

				@media (min-width: 520px) {
					font-size: 18px;
				}

				@media (min-width: 768px) {
					font-size: 24px;
				}
			}

			h2 {
				font-size: 24px;
				text-align: center;
				font-family: 'clash', sans-serif;
				text-transform: uppercase;
				font-weight: 700;

				@media (min-width: 520px) {
					font-size: 34px;
				}

				@media (min-width: 768px) {
					font-size: 55px;
				}

				@media (min-width: 960px) {
					font-size: 64px;
				}

				@media (min-width: 1200px) {
					width: 70%;
				}

				@media (min-width: 1440px) {
					width: 55%;
					font-size: 70px;
				}
			}

			h2,
			p {
				padding: 0;
				margin: 0;
			}
		}
		.circle {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			width: 260px;
			height: 260px;
			border-radius: 50%;
			display: flex;
			justify-content: center;
			align-items: center;
			overflow: hidden;

			@media (min-width: 762px) {
				width: 400px;
				height: 400px;
			}

			@media (min-width: 830px) {
				width: 450px;
				height: 450px;
			}

			@media (min-width: 1440px) {
				width: 550px;
				height: 550px;
			}
		}

		.circle-text-wrapper {
			width: 90%;
			height: 90%;
			position: absolute;
			animation: spin 15s linear infinite;

			@media (min-width: 375px) {
				width: 120%;
				height: 120%;
			}
		}

		.circle-svg {
			width: 100%;
			height: 100%;
			overflow: visible;
		}

		.circle-text {
			fill: white;
			font-size: 14px;
			font-family: 'clash', sans-serif;
			font-weight: 600;
			letter-spacing: 3.3px;
			text-transform: uppercase;
		}

		.mex-text {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			font-size: 36px;
			font-family: 'clash', sans-serif;
			font-weight: 700;
			color: white;
			letter-spacing: 4px;
			z-index: 2;

			@media (min-width: 375px) {
				font-size: 61.15px;
			}
		}

		@keyframes spin {
			0% {
				transform: rotate(0deg);
			}
			100% {
				transform: rotate(360deg);
			}
		}

		&__cards {
			position: relative;
			display: flex;
			flex-direction: column;
			gap: 20px;

			@media (min-width: 1440px) {
				height: 946px;
				.card {
					width: 350px;
				}
				.card:nth-of-type(2) {
					position: absolute;
					top: 0;
					left: 50%;
					transform: translateX(-50%);
				}

				.card:nth-of-type(3) {
					position: absolute;
					top: 312px;
					left: 0;
				}

				.card:nth-of-type(4) {
					position: absolute;
					bottom: 0;
					left: 80px;
				}

				.card:nth-of-type(5) {
					position: absolute;
					bottom: 0;
					right: 80px;
				}

				.card:nth-of-type(6) {
					position: absolute;
					top: 312px;
					right: 0;
				}
			}

			@media (min-width: 2000px) {
				width: 1600px;
				margin: 0 auto;
			}

			.card {
				position: relative;
				z-index: 5;
				display: flex;
				flex-direction: column;
				gap: 12px;
				border-radius: 12px;
				padding: 24px 32px;
				border: 1px solid rgba(255, 255, 255, 0.017);
				box-shadow:
					inset 0 0.3px 2px rgba(255, 255, 255, 0.744),
					0 5px 20px rgba(0, 0, 0, 0.5);
				background-color: rgba(0, 0, 0, 0.3);
				backdrop-filter: blur(100px);
				-webkit-backdrop-filter: blur(100px);

				@media (min-width: 768px) {
					padding: 32px 40px;
					gap: 16px;
				}

				@media (min-width: 1440px) {
					padding: 32px 40px 41px;
				}

				h3 {
					margin: 0;
					text-transform: uppercase;
					font-size: 16px;
					font-family: 'clash', sans-serif;
					font-weight: 700;
					color: #ffffff;

					span {
						color: #ffffff;
					}

					@media (min-width: 768px) {
						font-size: 24px;
					}
				}

				h3.colorful {
					color: #9799a1;
				}

				p {
					font-size: 14px;
					font-family: 'clash', sans-serif;
					font-weight: 400;
					color: #9799a1;
					margin: 0;
				}
			}

			.container {
				position: absolute;
				top: 8pc;
				left: -10pc;
				width: 450px;
				height: 450px;
				display: flex;
				justify-content: center;
				align-items: center;
				z-index: 1;
			}

			/* Markaziy aylana olov yorug'ligi */
			.fire-orb {
				position: relative;
				width: 300px;
				height: 300px;
				border-radius: 50%;
				/* Markazdan tarqaluvchi olovli ranglar */
				background: radial-gradient(
					circle,
					#ff8935 0%,
					#611d0c 40%,
					transparent 75%
				);
				filter: blur(50px);
				z-index: 10;
				animation: pulse-glow 5s infinite alternate ease-in-out;
			}

			/* Yana ham kengroq tuman effekti (orqa qatlam) */
			.fire-orb::before {
				content: '';
				position: absolute;
				top: -50px;
				left: -50px;
				right: -50px;
				bottom: -50px;
				background: radial-gradient(
					circle,
					rgba(97, 29, 12, 0.6) 0%,
					transparent 70%
				);
				filter: blur(80px);
				z-index: -1;
				opacity: 0.8;
			}

			/* Eng ichki issiq nuqta */
			.fire-orb::after {
				content: '';
				position: absolute;
				top: 30%;
				left: 30%;
				width: 40%;
				height: 40%;
				background: radial-gradient(
					circle,
					rgba(255, 137, 53, 0.8) 0%,
					transparent 80%
				);
				filter: blur(20px);
				z-index: 11;
			}

			/* Pulsatsiya animatsiyasi: yorug'likning o'ynashi */
			@keyframes pulse-glow {
				0% {
					transform: scale(0.95);
					opacity: 0.7;
				}
				100% {
					transform: scale(1.1);
					opacity: 1;
				}
			}

			/* Atrofdagi mayda uchqunlar yoki qo'shimcha yorug'lik */
			.ambient-glow {
				position: absolute;
				width: 600px;
				height: 600px;
				background: radial-gradient(
					circle,
					rgba(97, 29, 12, 0.2) 0%,
					transparent 60%
				);
				filter: blur(100px);
				pointer-events: none;
			}
		}
	}
</style>
